{
  "name": "forever-ecommerce",
  "private": true,
  "version": "1.0.0",
  "description": "Forever MERN e-commerce monorepo",
  "scripts": {
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "npm run server --prefix backend",
    "dev:admin": "npm run dev --prefix admin",
    "build:frontend": "npm run build --prefix frontend",
    "build:admin": "npm run build --prefix admin",
    "start:backend": "npm start --prefix backend",
    "install:all": "npm install --prefix frontend && npm install --prefix backend && npm install --prefix admin"
  }
}
